{
  "family": "${ECS_TASK_FAMILY}",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",

  "executionRoleArn": "${ECS_EXECUTION_ROLE_ARN}",
  "taskRoleArn": "${ECS_TASK_ROLE_ARN}",

  "containerDefinitions": [
    {
      "name": "bflow-backend",

      "image": "placeholder",

      "essential": true,

      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],

      "environment": [
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "prod"
        },
        {
          "name": "AWS_REGION",
          "value": "${AWS_REGION}"
        },
        {
          "name": "DB_SSL_MODE",
          "value": "require"
        },
        {
          "name": "COGNITO_ISSUER_URI",
          "value": "${COGNITO_ISSUER_URI}"
        },
        {
          "name": "AWS_SES_FROM_EMAIL",
          "value": "noreply@bflow-studio.com"
        },
        {
          "name": "LOGO_URL",
          "value": "https://res.cloudinary.com/dmv1q774l/image/upload/v1778910438/Bflow-logo-v1_yq5uyb.png"
        },
        {
          "name": "FRONTEND_URL",
          "value": "https://www.bflow-studio.com/"
        }
      ],

      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "${RDS_SECRET_ARN}:DB_HOST::"
        },
        {
          "name": "DB_PORT",
          "valueFrom": "${RDS_SECRET_ARN}:DB_PORT::"
        },
        {
          "name": "DB_NAME",
          "valueFrom": "${RDS_SECRET_ARN}:DB_NAME::"
        },
        {
          "name": "DB_USER",
          "valueFrom": "${RDS_SECRET_ARN}:DB_USER::"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "${RDS_SECRET_ARN}:DB_PASSWORD::"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",

        "options": {
          "awslogs-group": "${CLOUDWATCH_LOG_GROUP}",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}